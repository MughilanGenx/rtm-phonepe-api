{
    "openapi": "3.0.0",
    "info": {
        "title": "PhonePe Payment Gateway API",
        "description": "API Documentation for PhonePe Payment Integration",
        "version": "1.0.0"
    },
    "paths": {
        "/api/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "User Login",
                "description": "Authenticate a user and return a JWT token.",
                "operationId": "c373bc4cffa4a56fc64e3979b8ee7b96",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "user@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "secret"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login successful",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Login successful"
                                        },
                                        "data": {
                                            "properties": {
                                                "token": {
                                                    "type": "string",
                                                    "example": "eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9..."
                                                },
                                                "user": {
                                                    "type": "object"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Invalid credentials"
                    },
                    "422": {
                        "description": "Validation Error"
                    }
                }
            }
        },
        "/api/logout": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "User Logout",
                "description": "Log out the user by invalidating the JWT token.",
                "operationId": "5ff2dc8b48bff52908d3821a0ecc9b3e",
                "responses": {
                    "200": {
                        "description": "Logout successful",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Logout successful"
                                        },
                                        "data": {
                                            "type": "object",
                                            "example": null,
                                            "nullable": true
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/health": {
            "get": {
                "tags": [
                    "Health"
                ],
                "summary": "API Health Check",
                "description": "Returns API health status.",
                "operationId": "f5cd8cf984b7dabef10f8caeabcf4fd4",
                "responses": {
                    "200": {
                        "description": "API is healthy",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "ok"
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "API is healthy"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/generate-payment-link": {
            "post": {
                "tags": [
                    "Payment"
                ],
                "summary": "Generate Payment Link",
                "description": "Create a pending payment record and return a local shareable link.",
                "operationId": "65e4b3b75c5ae7adcc3e27058d5771f5",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "amount",
                                    "name",
                                    "email",
                                    "phone"
                                ],
                                "properties": {
                                    "amount": {
                                        "type": "number",
                                        "example": 100,
                                        "minimum": 1
                                    },
                                    "merchant_order_id": {
                                        "type": "string",
                                        "example": "ORDER_12345",
                                        "nullable": true
                                    },
                                    "name": {
                                        "type": "string",
                                        "example": "John Doe"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "john@example.com"
                                    },
                                    "phone": {
                                        "type": "string",
                                        "example": "9876543210"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Payment link generated successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Payment link generated successfully"
                                        },
                                        "data": {
                                            "properties": {
                                                "payment_id": {
                                                    "type": "integer",
                                                    "example": 1
                                                },
                                                "merchant_order_id": {
                                                    "type": "string",
                                                    "example": "ORDER_12345"
                                                },
                                                "payment_link": {
                                                    "type": "string",
                                                    "example": "http://localhost/api/pay/ORDER_12345"
                                                },
                                                "name": {
                                                    "type": "string",
                                                    "example": "John Doe"
                                                },
                                                "email": {
                                                    "type": "string",
                                                    "example": "john@example.com"
                                                },
                                                "phone": {
                                                    "type": "string",
                                                    "example": "9876543210"
                                                },
                                                "amount": {
                                                    "type": "number",
                                                    "example": 100
                                                },
                                                "status": {
                                                    "type": "string",
                                                    "example": "INITIATED"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error"
                    }
                }
            }
        },
        "/api/pay/{merchantOrderId}": {
            "get": {
                "tags": [
                    "Payment"
                ],
                "summary": "Process Shared Link",
                "description": "Look up the payment and redirect the user to PhonePe checkout.",
                "operationId": "48d905dc1bee91a1251f2201ce245761",
                "parameters": [
                    {
                        "name": "merchantOrderId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "302": {
                        "description": "Redirect to PhonePe checkout"
                    },
                    "404": {
                        "description": "Payment not found"
                    },
                    "400": {
                        "description": "Payment link already used"
                    },
                    "502": {
                        "description": "Payment initiation failed"
                    }
                }
            }
        },
        "/api/payment/callback/{merchantOrderId}": {
            "post": {
                "tags": [
                    "Payment"
                ],
                "summary": "PhonePe Redirect Callback",
                "description": "Handles PhonePe browser redirect after payment. Performs a server-to-server status verification, updates the DB, then redirects the frontend to /payment/status with query params: orderId, status (COMPLETED|PENDING|DECLINED|CANCELLED|ERROR), amount, transactionId, paidAt. On failure, an extra `error` param is included and status defaults to PENDING.",
                "operationId": "220072c31434ea471f6ba3ee9f4a4622",
                "parameters": [
                    {
                        "name": "merchantOrderId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "required": false,
                    "content": {
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "properties": {
                                    "transactionId": {
                                        "type": "string"
                                    },
                                    "merchantId": {
                                        "type": "string"
                                    },
                                    "providerReferenceId": {
                                        "type": "string"
                                    },
                                    "code": {
                                        "type": "string"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "302": {
                        "description": "Redirect to {FRONTEND_URL}/payment/status?orderId=&status=&amount=&transactionId=&paidAt="
                    }
                }
            }
        },
        "/api/webhook/phonepe": {
            "post": {
                "tags": [
                    "Payment"
                ],
                "summary": "PhonePe Webhook",
                "description": "Handle PhonePe server-to-server webhook notification.",
                "operationId": "a51b185fee6b86decd8d6a7fb2e2cec1",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "response": {
                                        "description": "Base64 encoded payload",
                                        "type": "string"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Webhook processed successfully"
                    },
                    "400": {
                        "description": "Invalid webhook payload - order ID missing"
                    },
                    "401": {
                        "description": "Invalid webhook signature"
                    },
                    "500": {
                        "description": "Webhook processing failed"
                    }
                }
            }
        },
        "/api/payment/status/{merchantOrderId}": {
            "get": {
                "tags": [
                    "Payment"
                ],
                "summary": "Check Payment Status",
                "description": "Manually check and sync payment status from PhonePe.",
                "operationId": "32800f625a27a94f25ae76865f180287",
                "parameters": [
                    {
                        "name": "merchantOrderId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Payment status returned successfully"
                    },
                    "202": {
                        "description": "Payment is being processed"
                    },
                    "400": {
                        "description": "Payment declined or errored"
                    },
                    "404": {
                        "description": "Payment not found"
                    },
                    "500": {
                        "description": "Status check error"
                    }
                }
            }
        },
        "/api/transactions": {
            "get": {
                "tags": [
                    "Payment"
                ],
                "summary": "List All Transactions",
                "description": "Return a paginated list of all payment records. Supports search, status filtering, date range filtering, and pagination.",
                "operationId": "5b52a85c7c2184a7eb583da9aa4737db",
                "parameters": [
                    {
                        "name": "search",
                        "in": "query",
                        "description": "Search by order ID, name, email, phone, or transaction ID",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "status",
                        "in": "query",
                        "description": "Filter by payment status (e.g., INIT, COMPLETED, PENDING, DECLINED, CANCELLED)",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "from_date",
                        "in": "query",
                        "description": "Start date (YYYY-MM-DD)",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "format": "date"
                        }
                    },
                    {
                        "name": "to_date",
                        "in": "query",
                        "description": "End date (YYYY-MM-DD)",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "format": "date"
                        }
                    },
                    {
                        "name": "per_page",
                        "in": "query",
                        "description": "Items per page (default: 10)",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 10
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Transactions fetched successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Transactions fetched successfully"
                                        },
                                        "data": {
                                            "properties": {
                                                "current_page": {
                                                    "type": "integer",
                                                    "example": 1
                                                },
                                                "data": {
                                                    "type": "array",
                                                    "items": {
                                                        "type": "object"
                                                    }
                                                },
                                                "total": {
                                                    "type": "integer",
                                                    "example": 50
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/transactions/{orderId}": {
            "get": {
                "tags": [
                    "Payment"
                ],
                "summary": "Get Transaction by Order ID",
                "description": "Fetch complete details of a specific payment transaction using its merchant order ID.",
                "operationId": "96c5a280c51eba4d62cb8a54f20ad879",
                "parameters": [
                    {
                        "name": "orderId",
                        "in": "path",
                        "description": "Merchant Order ID",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Transaction fetched successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Transaction fetched successfully"
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "properties": {
                                                    "id": {
                                                        "type": "integer",
                                                        "example": 17
                                                    },
                                                    "merchant_order_id": {
                                                        "type": "string",
                                                        "example": "ORDER_69D7771BBF"
                                                    },
                                                    "name": {
                                                        "type": "string",
                                                        "example": "lee"
                                                    },
                                                    "email": {
                                                        "type": "string",
                                                        "format": "email",
                                                        "example": "test@gmail.com"
                                                    },
                                                    "phone": {
                                                        "type": "string",
                                                        "example": "9999233434"
                                                    },
                                                    "amount": {
                                                        "type": "string",
                                                        "example": "11.00"
                                                    },
                                                    "status": {
                                                        "type": "string",
                                                        "example": "completed"
                                                    },
                                                    "payment_response": {
                                                        "description": "Raw response from PhonePe",
                                                        "type": "object",
                                                        "example": {
                                                            "state": "COMPLETED",
                                                            "amount": 1100,
                                                            "orderId": "OMO2604091523459403481676",
                                                            "currency": "INR",
                                                            "payableAmount": 1100
                                                        }
                                                    },
                                                    "last_synced_at": {
                                                        "type": "string",
                                                        "format": "date-time",
                                                        "example": "2026-04-09T09:54:54.000000Z"
                                                    },
                                                    "paid_at": {
                                                        "type": "string",
                                                        "format": "date-time",
                                                        "example": "2026-04-09T09:54:54.000000Z"
                                                    },
                                                    "created_at": {
                                                        "type": "string",
                                                        "format": "date-time",
                                                        "example": "2026-04-09T09:53:31.000000Z"
                                                    },
                                                    "updated_at": {
                                                        "type": "string",
                                                        "format": "date-time",
                                                        "example": "2026-04-09T09:54:54.000000Z"
                                                    }
                                                },
                                                "type": "object"
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Transaction not found"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        }
    },
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Auth",
            "description": "Authentication API Endpoints"
        },
        {
            "name": "Health",
            "description": "API health check endpoints"
        },
        {
            "name": "Payment",
            "description": "PhonePe Payment API Endpoints"
        }
    ]
}